{
  "include": ["./**/*.ts"],
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true,
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "node",
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "esModuleInterop": true
  }
}
