{
  "include": ["./**/*.ts"],
  "compilerOptions": {
    "skipLibCheck": true,
    "noEmit": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "es2022",
    "lib": ["es2022"],
    "sourceMap": true,
    "declaration": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "types": ["mocha"]
  }
}
