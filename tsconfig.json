{
  "compilerOptions": {
    "outDir": "lib",
    "rootDir": "./src",
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2023"],
    "sourceMap": true,
    "declaration": true,
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true
  },
  "include": ["./src/**/*.ts"],
  "ts-node": {
    "esm": true
  }
}
