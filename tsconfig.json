{
  "compilerOptions": {
    "outDir": "lib",
    "rootDir": "./src",
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "sourceMap": true,
    "declaration": true,
    "moduleResolution": "node",
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["./src/**/*.ts"]
}
